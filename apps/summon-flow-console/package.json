    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "start": "next start --port 30220",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@better-auth/passkey": "^1.6.2",
    "@prisma/adapter-pg": "^7.7.0",
