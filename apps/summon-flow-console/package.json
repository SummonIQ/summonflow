{
  "name": "@summoniq/summon-flow-console",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --port 30220 & stripe listen --forward-to http://localhost:30220/api/stripe/webhook & wait",
    "stripe:listen": "stripe listen --forward-to http://localhost:30220/api/stripe/webhook",
    "build": "prisma generate && next build",
