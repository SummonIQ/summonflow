    "framer-motion": "^12.38.0",
    "lucide-react": "^0.562.0",
    "next": "^16.2.2",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "stripe": "^22.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.16",
    "@types/node": "^24.9.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "dotenv": "^17.4.1",
    "postcss": "^8.5.6",
    "prisma": "^7.7.0",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.9.3"
  }
